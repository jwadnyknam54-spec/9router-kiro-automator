# =============================================================================
# 9Router-Kiro Automator Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!

# -----------------------------------------------------------------------------
# 9Router Configuration
# -----------------------------------------------------------------------------
# URL to your 9Router instance (default: http://localhost:20128)
ROUTER_URL=http://localhost:20128

# Password for your 9Router dashboard
# REQUIRED: Set this to your actual 9Router password
ROUTER_PASSWORD=your_password_here

# -----------------------------------------------------------------------------
# Browser Configuration
# -----------------------------------------------------------------------------
# Chrome DevTools Protocol URL (default: http://127.0.0.1:9222)
# Chrome must be running with: chrome.exe --remote-debugging-port=9222
CDP_URL=http://127.0.0.1:9222

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Path to SQLite database file
# Default: ~/.9router/data.db (auto-created)
DB_PATH=~/.9router/data.db

# Enable automatic backups (true/false)
# Default: true (keeps last 7 backups)
DB_BACKUP_ENABLED=true

# Backup directory path
# Default: ~/.9router/backups
DB_BACKUP_PATH=~/.9router/backups

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# Encryption key for credential storage (AES-256-GCM)
# REQUIRED: Generate with: npm run generate-key
# This must be a 64-character hex string (32 bytes)
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log output directory
LOG_DIR=./logs

# Enable console logging (true/false)
LOG_CONSOLE=true

# Enable file logging (true/false)
LOG_FILE=true

# Log format: text, json
LOG_FORMAT=text

# -----------------------------------------------------------------------------
# Rate Limiting Configuration
# -----------------------------------------------------------------------------
# Maximum accounts to create per day
# Recommended: 10 (prevents AWS abuse detection)
# WARNING: Higher values may trigger AWS anti-abuse systems
MAX_ACCOUNTS_PER_DAY=10

# Rate limit window in milliseconds
# Default: 86400000 (24 hours)
RATE_LIMIT_WINDOW=86400000

# -----------------------------------------------------------------------------
# Anti-Detection Configuration
# -----------------------------------------------------------------------------
# Enable anti-detection features (true/false)
ANTI_DETECTION_ENABLED=true

# Enable canvas fingerprint protection
CANVAS_NOISE=true

# Enable WebGL fingerprint protection
WEBGL_NOISE=true

# Enable audio fingerprint protection
AUDIO_NOISE=true

# Enable WebRTC protection (prevent IP leak)
WEBRTC_PROTECTION=true

# Enable user-agent rotation
USER_AGENT_ROTATION=true

# -----------------------------------------------------------------------------
# Automation Configuration
# -----------------------------------------------------------------------------
# Default cooldown between accounts (milliseconds)
# Default: 300000 (5 minutes)
# Recommended: 300000-900000 (5-15 minutes)
DEFAULT_COOLDOWN=300000

# Enable adaptive cooldown (increases after failures)
ADAPTIVE_COOLDOWN=true

# Maximum authorization polling attempts
# Default: 60 (5 minutes with 5-second intervals)
MAX_AUTH_ATTEMPTS=60

# Authorization polling interval (milliseconds)
# Default: 5000 (5 seconds)
AUTH_POLL_INTERVAL=5000

# -----------------------------------------------------------------------------
# Proxy Configuration (Optional)
# -----------------------------------------------------------------------------
# Proxy server URL (optional)
# Examples:
#   - HTTP: http://proxy.example.com:8080
#   - HTTPS: https://proxy.example.com:8080
#   - SOCKS5: socks5://proxy.example.com:1080
# PROXY_URL=

# Proxy list file (one proxy per line)
# PROXY_FILE=./config/proxies.txt

# Enable proxy rotation (true/false)
# PROXY_ROTATION=false

# -----------------------------------------------------------------------------
# AWS Configuration (Optional)
# -----------------------------------------------------------------------------
# AWS region for API calls
# AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Advanced Configuration (Optional)
# -----------------------------------------------------------------------------
# Browser connection retry attempts
# BROWSER_CONNECTION_ATTEMPTS=3

# Browser connection retry delay (milliseconds)
# BROWSER_CONNECTION_RETRY_DELAY=5000

# Browser headless mode (true/false)
# Default: false (headless mode reduces anti-detection effectiveness)
# BROWSER_HEADLESS=false

# Enable debug mode (verbose logging + screenshots)
# DEBUG_MODE=false

# Debug screenshot directory
# DEBUG_SCREENSHOT_DIR=./debug/screenshots

# Enable request logging (save all HTTP requests)
# ENABLE_REQUEST_LOGS=false

# Request logs directory
# REQUEST_LOGS_DIR=./logs/requests
